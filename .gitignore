__pycache__/
*.pyc
*.egg-info/
build/
dist/
.venv/
.pytest_cache/
.ruff_cache/
.env
data/cache/
data/test_*.sqlite3
data/test_*.sqlite3-journal
data/sample_*.html
# DB runtime (>100 Mo avec ~100k amendements) : persistance via actions/cache, pas via git
data/veille.sqlite3
data/veille.sqlite3-journal
data/*.sqlite3.bak.*
check_run.py
site/public/
site/resources/
site/content/items/*/
site/data/by_category/
site/data/by_chamber/
site/data/index.json
*.zip
*.tmp
.DS_Store
_tmp_*.py
site/content/_index.md

# Artefacts build Hugo + digest courant
site/.hugo_build.lock
data/last_digest.html
# Miroirs docs externes (schémas AN, volumineux + versionnés côté AN)
references/
# Scripts diagnostiques one-shot
scripts/diag_*.py
scripts/diag_*.txt
# Scripts one-shot commit/push generes par session (R22/R23/R24/R25...) :
# ne pas versionner, archiver au besoin. reset_db_full.command est un
# utilitaire reutilisable tenu hors git volontairement.
push_*.command
commit_*.command
deploy_*.command
finish_*.command
run_clean_*.command
cleanup_*.command
# R38 : scripts diag + reset ciblés (one-shot, auto-supprimés à l'exécution)
diag_*.command
reset_*.command
# Exception : reset_db_full.command est un utilitaire réutilisable (voir ci-dessus)
!reset_db_full.command

# Claude Code — settings.json est versionné (allowlist projet), settings.local.json
# perso est exclu (overrides locaux + token éventuel). Le sous-dossier worktrees/
# est aussi exclu (état de session Claude Code, branches éphémères).
.claude/settings.local.json
.claude/worktrees/

# R42-CH : dossiers d'assets téléchargés avec les fixtures HTML
# ("Save Page As" complete) — pas nécessaires aux tests, lourds (3 Mo+).
tests/*_files/

# R43-A : cache local des dumps open data AN (350 MB total) — généré par
# scripts/parlementaires_sport.py, ne doit pas vivre dans git.
data/parlementaires_cache/

# R43-M : cache local CSV séance Sénat pour la page PPL spéciale
data/special_ppl_cache/
